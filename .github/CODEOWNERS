# Default owner for the whole repository.
# This keeps solo-maintainer PRs reviewable today, and can be replaced
# with teams or additional maintainers as the project grows.
*                               @somoore

# Security-critical paths require explicit ownership.
# When the repo has multiple maintainers, keep these paths narrow and
# promote the owners below to teams or specific trusted reviewers.

# CI/CD and supply chain
/.github/                @somoore
/deny.toml               @somoore
/scripts/go-supply-chain.sh @somoore
/install.sh              @somoore
/Makefile                @somoore
/scripts/checksum.sh     @somoore
/aibom.json              @somoore

# Rust policy oracle (zero-dependency core)
/mister-core/            @somoore
/mister-shared/          @somoore
/Cargo.toml              @somoore
/Cargo.lock              @somoore

# Go hook handlers and policy bridge
/pkg/core/               @somoore
/pkg/hooks/              @somoore
/pkg/session/            @somoore
/pkg/lease/              @somoore

# Security policy and documentation
/SECURITY.md             @somoore
/CLAUDE.md               @somoore
/docs/contributor/supply-chain-policy.md       @somoore
/docs/research/security-verification-guide.md  @somoore
