{
  "_test_metadata": {
    "expected_verdict": "ask",
    "expected_reason": "Read of .env triggers ask; verify that the ledger entry for this event contains ONLY the path and hash, NEVER the file contents (DB_PASSWORD=hunter2 etc)",
    "hook_type": "PreToolUse",
    "ledger_assertions": {
      "must_contain": [".env", "sensitivity:secret", "sha256:"],
      "must_not_contain": ["DB_PASSWORD", "hunter2", "API_KEY=", "SECRET_KEY=", "aws_access_key_id"]
    },
    "session_state": {
      "secret_session": false,
      "recently_read_untrusted": false
    }
  },
  "tool_name": "Read",
  "tool_input": {
    "file_path": ".env"
  }
}
