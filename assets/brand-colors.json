{
  "meta": {
    "design_system": "sir design system v0.1",
    "reference": "assets/design-system.html",
    "note": "ANSI codes are standard 16-color only. Hex values are for web/documentation use. Neutral track is vellum+ink (warm cream on near-black)."
  },

  "neutral": {
    "paper": {
      "hex": "#FAF6EC",
      "usage": "Lightest surface — card backgrounds, inset wells"
    },
    "vellum_100": {
      "hex": "#F3EEE2",
      "usage": "Page background (light mode default)"
    },
    "vellum_200": {
      "hex": "#EBE5D5",
      "usage": "Hover state, alt row fill"
    },
    "vellum_300": {
      "hex": "#DDD5C0",
      "usage": "Borders, dividers, rule lines"
    },
    "ink_600": {
      "hex": "#4A463F",
      "usage": "Muted text, metadata, marginalia"
    },
    "ink_800": {
      "hex": "#2A2824",
      "usage": "Secondary text, captions"
    },
    "ink_900": {
      "hex": "#141311",
      "usage": "Primary text, headings, logo — light mode"
    }
  },

  "dark": {
    "surface_900": {
      "hex": "#0A0A08",
      "usage": "Terminal background, dark mode base"
    },
    "surface_800": {
      "hex": "#131210",
      "usage": "Terminal title bar, dark mode card"
    },
    "surface_700": {
      "hex": "#1E1D1A",
      "usage": "Dark mode border, divider"
    },
    "surface_600": {
      "hex": "#2A2824",
      "usage": "Dark mode hover"
    },
    "text_muted": {
      "hex": "#504A3F",
      "usage": "Dim text in terminal, deep muted"
    },
    "text_secondary": {
      "hex": "#B8B2A4",
      "usage": "Secondary text in dark mode"
    },
    "text_primary": {
      "hex": "#F3EEE2",
      "usage": "Primary text in dark mode / terminal"
    }
  },

  "verdict": {
    "allow": {
      "hex": "#2F7D3A",
      "hex_tint": "#EBEDE6",
      "ansi": "32",
      "glyph": "\u00b7",
      "glyph_name": "middle dot",
      "usage": "Allow verdicts, passing checks, clean session",
      "terminal_bright": "#4FAF58"
    },
    "ask": {
      "hex": "#B4660A",
      "hex_tint": "#F1E6D3",
      "ansi": "33",
      "glyph": "?",
      "glyph_name": "question mark",
      "usage": "Ask prompts, caution indicators, operator decision required",
      "terminal_bright": "#E29028"
    },
    "block": {
      "hex": "#B8261F",
      "hex_tint": "#F0DCD9",
      "ansi": "31",
      "glyph": "\u00d7",
      "glyph_name": "multiplication sign",
      "usage": "Deny verdicts, failed checks, tainted egress blocked",
      "terminal_bright": "#E24A44"
    },
    "info": {
      "hex": "#1E6E85",
      "hex_tint": "#D0E8EE",
      "ansi": "36",
      "glyph": "i",
      "glyph_name": "letter i",
      "usage": "File paths, informational highlights, session metadata",
      "terminal_bright": "#4FAEC4"
    }
  },

  "legacy_ansi": {
    "note": "These ANSI codes are stable across all terminal themes. Use the hex values above for web/docs only.",
    "muted": {
      "ansi": "2",
      "usage": "Timestamps, hashes, dim metadata"
    },
    "bold": {
      "ansi": "1",
      "usage": "Verdict keywords, emphasis"
    },
    "reset": {
      "ansi": "0",
      "usage": "Reset after any colored span"
    }
  }
}
